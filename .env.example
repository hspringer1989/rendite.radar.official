# ── Claude ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_DAILY_BUDGET_EUR=2.0
# claude | fake  (fake = offline testing without API costs)
LLM_PROVIDER=claude

# ── TTS ───────────────────────────────────────────────────────────────────
# elevenlabs | fake
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
# German voice from the ElevenLabs voice library
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
TTS_DAILY_BUDGET_CHARS=15000

# ── Trend collectors ──────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=reel-autopilot/0.1 by <reddit-username>
REDDIT_SUBREDDITS=Finanzen,mauerstrassenwetten,Aktien
# comma-separated; defaults cover German finance news if left empty
RSS_FEEDS=
GOOGLE_TRENDS_GEO=DE

# ── B-roll footage ────────────────────────────────────────────────────────
PEXELS_API_KEY=

# ── Rendering ─────────────────────────────────────────────────────────────
FFMPEG_BIN=ffmpeg
REEL_TARGET_SECONDS=45
MUSIC_VOLUME_DB=-18

# ── Review via Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Instagram publishing (Phase 2) ────────────────────────────────────────
IG_ACCESS_TOKEN=
IG_USER_ID=
# Default: Instagram-Login variant (creator account, no Facebook page).
# Classic Facebook-Login variant: set https://graph.facebook.com + FB_APP_ID/SECRET.
GRAPH_BASE_URL=https://graph.instagram.com
FB_APP_ID=
FB_APP_SECRET=
GRAPH_API_VERSION=v23.0
# public base URL under which PUBLIC_MEDIA_DIR is served (nginx on the server)
PUBLIC_MEDIA_BASE_URL=
PUBLIC_MEDIA_DIR=
POSTING_SLOTS=08:00,12:30,18:00
TIMEZONE=Europe/Berlin

# ── Branding ──────────────────────────────────────────────────────────────
# Keep aligned with the connected IG account (see `python main.py verify-ig`).
BRAND_NAME=Renditeradar
BRAND_HANDLE=@rendite.radar.official

# ── Stocks / daily story pipeline ─────────────────────────────────────────
# yfinance | fake  (fake = offline, no network)
STOCK_DATA_PROVIDER=yfinance
# Ticker universe (US + EU; EU tickers need an exchange suffix like SAP.DE).
STOCK_UNIVERSE=
STOCK_CANDIDATES_COUNT=4
# Blended factor weights (no sentiment), should sum to 1.0
STOCK_W_TECH=0.5
STOCK_W_FUND=0.5
STOCK_ATR_STOP_MULT=2.0
STOCK_ATR_TP_MULT=4.0
# Local time to build the daily earnings + watchlist stories
STOCK_STORY_SLOT=09:00
# Story posting slots (local TIMEZONE); one story per slot.
# Earnings + watchlist-overview in the morning, candidates at their market's hours.
STORY_POST_EARNINGS_SLOT=09:30
STORY_SLOTS_EU=10:30,13:00,15:00
STORY_SLOTS_US=16:00,18:30,20:30

# ── Pipeline ──────────────────────────────────────────────────────────────
MIN_TREND_SCORE=0.65
