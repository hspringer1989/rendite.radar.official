# ── Claude ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_DAILY_BUDGET_EUR=2.0
# claude | fake  (fake = offline testing without API costs)
LLM_PROVIDER=claude

# ── TTS ───────────────────────────────────────────────────────────────────
# elevenlabs | fake
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
# German voice from the ElevenLabs voice library
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
TTS_DAILY_BUDGET_CHARS=15000

# ── Trend collectors ──────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=reel-autopilot/0.1 by <reddit-username>
REDDIT_SUBREDDITS=Finanzen,mauerstrassenwetten,Aktien
# comma-separated; defaults cover German finance news if left empty
RSS_FEEDS=
GOOGLE_TRENDS_GEO=DE

# ── B-roll footage ────────────────────────────────────────────────────────
PEXELS_API_KEY=

# ── Rendering ─────────────────────────────────────────────────────────────
FFMPEG_BIN=ffmpeg
REEL_TARGET_SECONDS=45
MUSIC_VOLUME_DB=-18

# ── Review via Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Instagram publishing (Phase 2) ────────────────────────────────────────
IG_ACCESS_TOKEN=
IG_USER_ID=
# Default: Instagram-Login variant (creator account, no Facebook page).
# Classic Facebook-Login variant: set https://graph.facebook.com + FB_APP_ID/SECRET.
GRAPH_BASE_URL=https://graph.instagram.com
FB_APP_ID=
FB_APP_SECRET=
GRAPH_API_VERSION=v23.0
# public base URL under which PUBLIC_MEDIA_DIR is served (nginx on the server)
PUBLIC_MEDIA_BASE_URL=
PUBLIC_MEDIA_DIR=
POSTING_SLOTS=08:00,12:30,18:00
TIMEZONE=Europe/Berlin

# ── Branding ──────────────────────────────────────────────────────────────
BRAND_NAME=Renditeradar

# ── Pipeline ──────────────────────────────────────────────────────────────
MIN_TREND_SCORE=0.65
